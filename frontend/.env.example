# Production / direct API: set your public Django URL (no trailing slash).
# Dev: leave unset to use Vite’s /api proxy (see vite.config.js) — avoids CORS.
# VITE_API_URL=http://127.0.0.1:8000
# JWT access token for admin API (Bearer). Legacy alias: VITE_DRF_TOKEN
# Get tokens:  cd backend && pip install -r requirements.txt && python manage.py init_admin
# Or POST /api/auth/token/ with {"username","password"}
VITE_JWT_ACCESS=
# Optional: refresh token for automatic access renewal (POST /api/auth/token/refresh/)
VITE_JWT_REFRESH=
# Legacy — still read if VITE_JWT_ACCESS is empty
VITE_DRF_TOKEN=
