# Default: Vite proxies /api → Django (http://127.0.0.1:8000). No CORS issues.
# Run:  backend: python manage.py runserver   |   frontend: npm run dev
#
# To call Django directly from the browser instead, uncomment:
# VITE_API_URL=http://127.0.0.1:8000

# Optional: paste JWT from `python manage.py init_admin` instead of logging in via /admin
# VITE_JWT_ACCESS=
# VITE_JWT_REFRESH=
